# SQLite database
DATABASE_URL="file:./prisma/dev.db"

# Core auth/license
BARBER_LICENSE_KEY="LICENSE_KEY"
HOME_USERS_DB_PATH="./data/home-users.db"
HOME_JWT_SECRET="change-me-home-secret"
HOME_JWT_EXPIRES_IN="30d"

# Telegram auth
TELEGRAM_BOT_USERNAME="your_bot_username"
HOME_TELEGRAM_AUTH_TTL_MS="600000"
BOT_PYTHON_PATH="./.venv/bin/python"

# Linux deployment / runtime
APP_RESTART_MODE="auto" # auto|spawn|exit
APP_TIMEZONE="Europe/Moscow"
BACKUP_CRON_EXPRESSION="0 3 * * *"
BACKUP_CRON_TIMEZONE="Asia/Irkutsk"
UPDATE_COMMAND_MAX_BUFFER_BYTES="10485760"
UPDATE_NPM_INSTALL_COMMAND="npm ci"

# Health checks
HEALTHCHECK_PATH="/api/health"
POST_RESTART_HEALTHCHECK_ENABLED="true"
POST_RESTART_HEALTHCHECK_TIMEOUT_MS="45000"
POST_RESTART_HEALTHCHECK_INTERVAL_MS="1500"
POST_RESTART_HEALTHCHECK_HOST="127.0.0.1"
HEALTHCHECK_TIMEOUT_SECONDS="45"
HEALTHCHECK_INTERVAL_SECONDS="2"
