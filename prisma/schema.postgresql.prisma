datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-postgresql-client"
}

model Cities {
  id         String   @id @default(uuid())
  name       String
  slug       String?
  isActive   Boolean  @default(true)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  barbers        Barbers[]
  services       Services[]
  positions      Positions[]
  shopCategories ShopCategories[]
  shopProducts   ShopProducts[]
  shopOrders     ShopOrders[]

  @@map("Cities")
}


model Users {
  id                   String  @id
  Name                 String? @map("Name")
  Phone                String? @map("Phone")
  LastNameChanged      String? @map("LastNameChanged")
  Barber               String? @map("Barber")
  homePasswordHash     String? @map("HomePasswordHash")
  homePasswordSalt     String? @map("HomePasswordSalt")
  homeIsActive         Boolean @default(true) @map("HomeIsActive")
  homeCreatedAt        String? @map("HomeCreatedAt")
  homeUpdatedAt        String? @map("HomeUpdatedAt")
  homeLastLoginAt      String? @map("HomeLastLoginAt")
  homePhoneChangedAt   String? @map("HomePhoneChangedAt")
  LastHaircutReminderSent String? @map("LastHaircutReminderSent")

  @@index([Phone])
  @@map("Users")
}

model Appointments {
  id                   String   @id
  customerName         String?  @map("CustomerName")
  phone                String?  @map("Phone")
  barber               String?  @map("Barber")
  date                 String?  @map("Date")
  time                 String?  @map("Time")
  status               String?  @map("Status")
  services             String?  @map("Services")
  reminder2hClientSent Boolean? @map("Reminder2hClientSent")
  reminder2hBarberSent Boolean? @map("Reminder2hBarberSent")
  userId               String?  @map("UserID")
  comment              String?  @map("Comment")
  coverBs              Int?     @map("CoverBs")
  discountRub          Int?     @map("DiscountRub")
  cityId               String?  @map("cityId")

  @@index([cityId])
  @@map("Appointments")
}


model Schedules {
  id        String   @id
  barber    String?  @map("Barber")
  dayOfWeek String?  @map("DayOfWeek")
  today     Boolean? @map("Today")
  date      String?  @map("Date")
  week      String?  @map("Week")
  time      String?  @map("Time")
  cityId    String?  @map("cityId")

  @@index([cityId])
  @@map("Schedules")
}


enum BarberRole {
  owner
  staff
}

model Barbers {
  id                 String        @id
  name               String
  nickname           String?
  description        String?
  rating             String?
  avatarUrl          String?
  color              String?
  phone              String?
  login              String?
  password           String?
  cardTitle          String        @default("")
  cardDescription    String        @default("")
  cardPhrase         String        @default("")
  cardMode           String        @default("generated")
  cardImageUrl       String        @default("")
  cardPhotoGrayscale Boolean       @default(true)
  cardPhotoOutline   Boolean       @default(true)
  isActive           Boolean       @default(true)
  orderIndex         Int           @default(0)
  role               BarberRole    @default(owner)
  positionId         String?
  cityId             String?       @map("cityId")
  position           Positions?    @relation(fields: [positionId], references: [id], onDelete: SetNull)
  city               Cities?       @relation(fields: [cityId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  lastSeenAt         DateTime?

  services     ServicePrices[]
  levelHistory BarberLevelHistory[]
}


model Positions {
  id                      String   @id
  name                    String
  masterSharePercent      Float?   @default(0)
  orderIndex              Int      @default(0)
  requiredClientVolume    Int?     @default(0)
  requiredRetainedClients Int?     @default(0)
  targetReturnPercent     Float?   @default(0)
  specialConditions       String?
  privileges              String?
  parentId                String?
  cityId                  String?  @map("cityId")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  parent                  Positions?  @relation("PositionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children                Positions[] @relation("PositionHierarchy")
  city                    Cities?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  barbers                 Barbers[]
  serviceMaxPrices        PositionServiceMaxPrices[]
  currentLevelHistory     BarberLevelHistory[] @relation("CurrentLevelHistory")
  nextLevelHistory        BarberLevelHistory[] @relation("NextLevelHistory")
}


model Services {
  id          String   @id
  name        String
  description String?
  category    String?
  duration    Int      @default(0)
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  cityId      String?  @map("cityId")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  city              Cities?                  @relation(fields: [cityId], references: [id], onDelete: SetNull)
  prices            ServicePrices[]
  positionMaxPrices PositionServiceMaxPrices[]
}


model ServicePrices {
  id        String   @id
  serviceId String
  barberId  String
  price     Float    @default(0)
  createdAt DateTime @default(now())

  service Services @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  barber  Barbers  @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([serviceId, barberId])
}

model PositionServiceMaxPrices {
  id         String   @id
  positionId String
  serviceId  String
  maxPrice   Float    @default(0)
  createdAt  DateTime @default(now())

  position Positions @relation(fields: [positionId], references: [id], onDelete: Cascade)
  service  Services  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([positionId, serviceId])
}

model BarberLevelHistory {
  id                      String   @id
  barberId                String
  month                   String
  actualClientVolume      Int      @default(0)
  actualRetainedClients   Int      @default(0)
  actualReturnPercent     Float    @default(0)
  meetsCurrentRequirements Boolean @default(false)
  meetsNextRequirements   Boolean @default(false)
  currentPositionId       String
  nextPositionId          String?
  evaluatedAt             DateTime @default(now())

  barber          Barbers     @relation(fields: [barberId], references: [id], onDelete: Cascade)
  currentPosition Positions @relation("CurrentLevelHistory", fields: [currentPositionId], references: [id], onDelete: Cascade)
  nextPosition    Positions? @relation("NextLevelHistory", fields: [nextPositionId], references: [id], onDelete: SetNull)

  @@unique([barberId, month])
  @@map("BarberLevelHistory")
}

model BotMessages {
  id        String   @id
  code      String   @unique
  title     String?
  text      String
  updatedAt DateTime @updatedAt
}

model BookingSettings {
  id           String   @id
  aboutText    String   @default("")
  bookingLimit Int      @default(2)
  minLeadHours Int      @default(2)
  maxDaysAhead Int      @default(14)
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeUserMeta {
  userId    String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("HomeUserMeta")
}

model BlockedUsers {
  id        String    @id
  userId    String    @unique
  reason    String?
  blockedAt DateTime  @default(now())
  blockedBy String?

  @@map("BlockedUsers")
}

model BarberAliases {
  id        String   @id
  barberId  String
  alias     String
  createdAt DateTime @default(now())

  @@unique([barberId, alias])
  @@map("BarberAliases")
}

model Businesses {
  id              String   @id
  name            String
  subdomain       String   @unique
  customDomain    String?  @unique
  customCrmDomain String?  @unique
  dbSchema        String   @unique
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  income CreatorIncome[]

  @@map("Businesses")
}

model CreatorIncome {
  id          String   @id
  businessId  String
  amount      Float
  periodStart String?
  periodEnd   String?
  date        String
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Businesses @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([date])
  @@map("CreatorIncome")
}

model ShopCategories {
  id         String   @id @default(uuid())
  name       String
  isActive   Boolean  @default(true)
  orderIndex Int      @default(0)
  cityId     String?  @map("cityId")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  city     Cities?       @relation(fields: [cityId], references: [id], onDelete: SetNull)
  products ShopProducts[]
}


model ShopProducts {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  categoryId  String?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  cityId      String?  @map("cityId")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  city       Cities?          @relation(fields: [cityId], references: [id], onDelete: SetNull)
  category   ShopCategories?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems ShopOrderItems[]
  stockEdits ShopStockEdits[]
}


model ShopOrders {
  id             String    @id @default(uuid())
  customerName   String?
  customerPhone  String?
  userId         String?
  status         String    @default("new")
  totalAmount    Float
  paymentMethod  String    @default("cash")
  bsAmount       Float     @default(0)
  comment        String?
  qrCode         String?   @unique
  issuedById     String?
  issuedByName   String?
  issuedAt       DateTime?
  cityId         String?   @map("cityId")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  city  Cities?          @relation(fields: [cityId], references: [id], onDelete: SetNull)
  items ShopOrderItems[]
}


model ShopOrderItems {
  id        String   @id @default(uuid())
  orderId   String
  productId String?
  name      String
  price     Float
  quantity  Int      @default(1)

  order   ShopOrders     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product ShopProducts?  @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model ShopStockEdits {
  id          String   @id @default(uuid())
  productId   String
  productName String
  delta       Int
  reason      String?
  editorId    String?
  editorName  String?
  createdAt   DateTime @default(now())

  product ShopProducts @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CrmNotificationHistory {
  id           String   @id @default(uuid())
  type         String
  title        String
  message      String
  barbershopId String?
  action       String?
  target       String?
  targetTable  String?
  recordId     String?
  createdAt    DateTime @default(now())

  @@index([barbershopId, createdAt])
  @@map("CrmNotificationHistory")
}

