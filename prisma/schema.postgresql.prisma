datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-postgresql-client"
}

model Users {
  id                   String  @id
  TelegramID           Float?  @map("TelegramID")
  Name                 String? @map("Name")
  Phone                String? @map("Phone")
  LastNameChanged      String? @map("LastNameChanged")
  Barber               String? @map("Barber")
  homePasswordHash     String? @map("HomePasswordHash")
  homePasswordSalt     String? @map("HomePasswordSalt")
  homeIsActive         Boolean @default(true) @map("HomeIsActive")
  homeCreatedAt        String? @map("HomeCreatedAt")
  homeUpdatedAt        String? @map("HomeUpdatedAt")
  homeLastLoginAt      String? @map("HomeLastLoginAt")
  homePhoneChangedAt   String? @map("HomePhoneChangedAt")
  homeTelegramChangedAt String? @map("HomeTelegramChangedAt")
  LastHaircutReminderSent String? @map("LastHaircutReminderSent")

  @@index([Phone])
  @@index([TelegramID])
  @@map("Users")
}

model Appointments {
  id                   String   @id
  CustomerName         String?  @map("CustomerName")
  Phone                String?  @map("Phone")
  Barber               String?  @map("Barber")
  Date                 String?  @map("Date")
  Time                 String?  @map("Time")
  Status               String?  @map("Status")
  Services             String?  @map("Services")
  Reminder2hClientSent Boolean? @map("Reminder2hClientSent")
  Reminder2hBarberSent Boolean? @map("Reminder2hBarberSent")
  UserID               String?  @map("UserID")
  Comment              String?  @map("Comment")
  CoverBs              Int?     @map("CoverBs")
  DiscountRub          Int?     @map("DiscountRub")

  @@map("Appointments")
}

model Schedules {
  id        String   @id
  Barber    String?  @map("Barber")
  DayOfWeek String?  @map("DayOfWeek")
  Today     Boolean? @map("Today")
  Date      String?  @map("Date")
  Week      String?  @map("Week")
  Time      String?  @map("Time")

  @@map("Schedules")
}

enum BarberRole {
  owner
  staff
}

model Barbers {
  id                 String        @id
  name               String
  nickname           String?
  description        String?
  rating             String?
  avatarUrl          String?
  color              String?
  phone              String?
  telegramId         String?
  login              String?
  password           String?
  cardTitle          String        @default("")
  cardDescription    String        @default("")
  cardPhrase         String        @default("")
  cardMode           String        @default("generated")
  cardImageUrl       String        @default("")
  cardPhotoGrayscale Boolean       @default(true)
  cardPhotoOutline   Boolean       @default(true)
  isActive           Boolean       @default(true)
  orderIndex         Int           @default(0)
  role               BarberRole    @default(owner)
  positionId         String?
  position           Positions?    @relation(fields: [positionId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  services ServicePrices[]
}

model Positions {
  id                      String   @id
  name                    String   @unique
  masterSharePercent      Float?   @default(0)
  orderIndex              Int      @default(0)
  requiredClientVolume    Int?     @default(0)
  requiredRetainedClients Int?     @default(0)
  targetReturnPercent     Float?   @default(0)
  specialConditions       String?
  privileges              String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  barbers           Barbers[]
  serviceMaxPrices  PositionServiceMaxPrices[]
}

model Services {
  id          String   @id
  name        String
  description String?
  category    String?
  duration    Int      @default(0)
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prices            ServicePrices[]
  positionMaxPrices PositionServiceMaxPrices[]
}

model ServicePrices {
  id        String   @id
  serviceId String
  barberId  String
  price     Float    @default(0)
  createdAt DateTime @default(now())

  service Services @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  barber  Barbers  @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([serviceId, barberId])
}

model PositionServiceMaxPrices {
  id         String   @id
  positionId String
  serviceId  String
  maxPrice   Float    @default(0)
  createdAt  DateTime @default(now())

  position Positions @relation(fields: [positionId], references: [id], onDelete: Cascade)
  service  Services  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([positionId, serviceId])
}

model BotSettings {
  id             String   @id
  botDescription String   @default("")
  aboutText      String   @default("")
  isBotEnabled   Boolean  @default(true)
  bookingLimit   Int      @default(2)
  minLeadHours   Int      @default(2)
  maxDaysAhead   Int      @default(14)
  lastSyncSource String   @default("site")
  botToken       String   @default("")
  updatedAt      DateTime @updatedAt
}

model BotMessages {
  id        String   @id
  code      String   @unique
  title     String?
  text      String
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeUserMeta {
  userId    String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("HomeUserMeta")
}

model TelegramAuthRequests {
  id           String  @id
  code         String  @unique
  status       String
  flow         String  @default("login")
  targetUserId String?
  telegramId   String?
  phone        String?
  displayName  String?
  userId       String?
  errorMessage String?
  createdAt    String
  expiresAt    String
  updatedAt    String

  @@index([status, expiresAt])
  @@index([flow, targetUserId])
  @@index([code])
  @@map("TelegramAuthRequests")
}

model BlockedUsers {
  id        String    @id
  userId    String    @unique
  reason    String?
  blockedAt DateTime  @default(now())
  blockedBy String?

  @@map("BlockedUsers")
}

model BarberAliases {
  id        String   @id
  barberId  String
  alias     String
  createdAt DateTime @default(now())

  @@unique([barberId, alias])
  @@map("BarberAliases")
}

model BotMenu {
  id        String   @id @default("default")
  payload   Json
  updatedAt DateTime @updatedAt

  @@map("BotMenu")
}

model Businesses {
  id              String   @id
  name            String
  subdomain       String   @unique
  customDomain    String?  @unique
  customCrmDomain String?  @unique
  dbSchema        String   @unique
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  income CreatorIncome[]

  @@map("Businesses")
}

model CreatorIncome {
  id          String   @id
  businessId  String
  amount      Float
  periodStart String?
  periodEnd   String?
  date        String
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Businesses @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([date])
  @@map("CreatorIncome")
}

model ShopCategories {
  id         String   @id @default(uuid())
  name       String
  isActive   Boolean  @default(true)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products ShopProducts[]
}

model ShopProducts {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  categoryId  String?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   ShopCategories?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems ShopOrderItems[]
  stockEdits ShopStockEdits[]
}

model ShopOrders {
  id             String    @id @default(uuid())
  customerName   String?
  customerPhone  String?
  userId         String?
  status         String    @default("new")
  totalAmount    Float
  paymentMethod  String    @default("cash")
  bsAmount       Float     @default(0)
  comment        String?
  qrCode         String?   @unique
  issuedById     String?
  issuedByName   String?
  issuedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items ShopOrderItems[]
}

model ShopOrderItems {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int      @default(1)

  order   ShopOrders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product ShopProducts @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ShopStockEdits {
  id          String   @id @default(uuid())
  productId   String
  productName String
  delta       Int
  reason      String?
  editorId    String?
  editorName  String?
  createdAt   DateTime @default(now())

  product ShopProducts @relation(fields: [productId], references: [id], onDelete: Cascade)
}

