# Copy this file to `.env` and fill real values there.
# `.env.example` stays in git as a safe template only.

# PostgreSQL runtime
PRISMA_RUNTIME="postgres"
POSTGRES_DATABASE_URL="postgresql://db_user:db_password@127.0.0.1:5432/barber_bot?schema=public"
POSTGRES_SHADOW_DATABASE_URL="postgresql://db_user:db_password@127.0.0.1:5432/barber_bot_shadow?schema=public"
POSTGRES_PORTABLE_HOME="./.local/postgresql-portable"
POSTGRES_PORTABLE_DATA_DIR="./.local/postgresql-portable/data-smoke"
POSTGRES_PORTABLE_PORT="54329"

# Core auth/license
# Generate these once and keep them stable in the real `.env`.
# PowerShell example:
# [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Max 256 }))
BARBER_LICENSE_KEY="LICENSE_KEY"
JWT_SECRET="replace-with-long-random-secret"
HOME_JWT_SECRET="replace-with-long-random-home-secret"
BOT_INTERNAL_API_TOKEN="replace-with-long-random-bot-token"

# Legacy-only: old SQLite snapshot used only for one-time import/migration
HOME_USERS_DB_PATH="./data/home-users.db"
LEGACY_SQLITE_SNAPSHOT_PATH=""
LEGACY_SQLITE_DATABASE_URL=""

HOME_JWT_EXPIRES_IN="30d"

# Emergency creator account is disabled by default.
# Leave it disabled unless you intentionally need a temporary break-glass login.
CREATOR_ENABLED="false"
CREATOR_LOGIN=""
CREATOR_PHONE=""
CREATOR_PASSWORD=""
CREATOR_NAME="Создатель"

# Browser origins allowed to call API cross-origin, comma-separated.
ALLOWED_ORIGINS="https://brothershop.website,https://www.brothershop.website,https://panel.brothershop.website"

# Telegram auth
TELEGRAM_BOT_USERNAME="your_bot_username_without_at"
HOME_TELEGRAM_AUTH_TTL_MS="600000"
BOT_PYTHON_PATH="./.venv/bin/python"

# Linux deployment / runtime
NODE_ENV="production"
PORT="3000"
APP_RESTART_MODE="auto"
APP_TIMEZONE="Asia/Irkutsk"
BACKUP_CRON_EXPRESSION="0 3 * * *"
BACKUP_CRON_TIMEZONE="Asia/Irkutsk"
UPDATE_COMMAND_MAX_BUFFER_BYTES="10485760"
UPDATE_NPM_INSTALL_COMMAND="npm ci"

# Health checks
HEALTHCHECK_PATH="/api/health"
POST_RESTART_HEALTHCHECK_ENABLED="true"
POST_RESTART_HEALTHCHECK_TIMEOUT_MS="45000"
POST_RESTART_HEALTHCHECK_INTERVAL_MS="1500"
POST_RESTART_HEALTHCHECK_HOST="127.0.0.1"
POST_RESTART_HEALTHCHECK_PORT="3000"
HEALTHCHECK_TIMEOUT_SECONDS="45"
HEALTHCHECK_INTERVAL_SECONDS="2"
